<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/main.css" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-rbsA2VBKQhggwzxH7pPCaAqO46MgnOM80zW1RWuH61DGLwZJEdK2Kadq2F9CUG65"
      crossorigin="anonymous"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.css"
      integrity="sha512-5A8nwdMOWrSz20fDsjczgUidUBR8liPYU+WymTZP1lmY9G6Oc7HlZv156XqnsgNUzTyMefFTcsFH/tnJE/+xBg=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />

    <title>Portfolio</title>
  </head>
  <body>
    <div class="frame">
      <div class="main_frame">
        <div class="left_frame">
          <div class="left_frame">
            <div class="left_1">
              <div class="left_1_1">
                <img
                  src="/author/images/Profile.png"
                  width="156px"
                  height="142px"
                  alt=""
                />
              </div>
              <div class="left_1_2"><%=user.name%></div>
              <div class="left_1_3"><%=user.profession%></div>
              <div class="left_icons">
                <a class="link_href">
                  <div class="icon">
                    <img src="/author/Icons-facebook.svg" class="icon-1" />
                  </div>
                </a>
                <a class="link_href" href="">
                  <div class="icon">
                    <img src="/author/Icons-instagram.svg" class="icon-1" />
                  </div>
                </a>
                <a class="link_href" href="">
                  <div class="icon">
                    <img src="/author/Icons-linkedin.svg" class="icon-1" />
                  </div>
                </a>
                <a class="link_href" href="">
                  <div class="icon">
                    <img src="/author/Icons-twitter.svg" class="icon-1" />
                  </div>
                </a>
                <a class="link_href" href="">
                  <div class="icon">
                    <img src="/author/Icons-Youtube.svg" class="icon-1" />
                  </div>
                </a>
                <a class="link_href" href="">
                  <div class="icon">
                    <img src="/author/Icons-dribbble.svg" class="icon-1" />
                  </div>
                </a>
              </div>
            </div>
            <div class="marginer"></div>
            <div class="left_2">
              <div class="self_info">
                <span class="info_label">Age:</span>
                <span class="info_ans"><%= user.age%></span>
              </div>
              <div class="self_info">
                <span class="info_label">Residence:</span>
                <span class="info_ans"><%= user.residence %></span>
              </div>
              <div class="self_info">
                <span class="info_label">Freelance:</span>
                <span class="info_ans">Available</span>
              </div>
              <div class="self_info">
                <span class="info_label">Address:</span>
                <span class="info_ans"><%= user.address %></span>
              </div>
            </div>
            <div class="marginer"></div>
            <div class="left_3">
              <h3 class="section_title">Language</h3>
              <div class="lang_box">
                <div class="lang_top">
                  <span class="lang_name">Uzbek</span>
                  <span class="lang_level">100%</span>
                </div>
                <div class="progress_bar">
                  <div class="progress_fill w_100"></div>
                </div>
              </div>
              <div class="lang_box">
                <div class="lang_top">
                  <span class="lang_name">Korean</span>
                  <span class="lang_level">85%</span>
                </div>
                <div class="progress_bar">
                  <div class="progress_fill w_85"></div>
                </div>
              </div>
              <div class="lang_box">
                <div class="lang_top">
                  <span class="lang_name">English</span>
                  <span class="lang_level">45%</span>
                </div>
                <div class="progress_bar">
                  <div class="progress_fill w_45"></div>
                </div>
              </div>
            </div>
            <div class="marginer"></div>
            <div class="left_4">
              <h3 class="section_title">Extra Skills</h3>
              <div class="lang_box">
                <div class="lang_top">
                  <span class="lang_name">HTML</span>
                  <span class="lang_level">88%</span>
                </div>
                <div class="progress_bar">
                  <div class="progress_fill w_88"></div>
                </div>
              </div>
              <div class="lang_box">
                <div class="lang_top">
                  <span class="lang_name">Css</span>
                  <span class="lang_level">99%</span>
                </div>
                <div class="progress_bar">
                  <div class="progress_fill w_99"></div>
                </div>
              </div>
              <div class="lang_box">
                <div class="lang_top">
                  <span class="lang_name">JS</span>
                  <span class="lang_level">100%</span>
                </div>
                <div class="progress_bar">
                  <div class="progress_fill w_100"></div>
                </div>
              </div>
              <div class="lang_box">
                <div class="lang_top">
                  <span class="lang_name">NodeJS</span>
                  <span class="lang_level">100%</span>
                </div>
                <div class="progress_bar">
                  <div class="progress_fill w_100"></div>
                </div>
              </div>
              <div class="lang_box">
                <div class="lang_top">
                  <span class="lang_name">Python</span>
                  <span class="lang_level">100%</span>
                </div>
                <div class="progress_bar">
                  <div class="progress_fill w_100"></div>
                </div>
              </div>
            </div>
            <div class="marginer"></div>
            <div class="left_5">
              <h3 class="last_section">Extra Skills</h3>
              <div class="extra_item">
                <img
                  src="/author/Icons.svg"
                  class="icon_check"
                  alt="icon_check"
                />
                <span>Bootstrap, Materialize</span>
              </div>
              <div class="extra_item">
                <img
                  src="/author/Icons.svg"
                  class="icon_check"
                  alt="icon_check"
                />
                <span>Styling, Sass</span>
              </div>
              <div class="extra_item">
                <img
                  src="/author/Icons.svg"
                  class="icon_check"
                  alt="icon_check"
                />
                <span>Django, Flask</span>
              </div>
            </div>
          </div>
        </div>
        <div class="mid_frame">
          <div class="musk_card">
            <div class="musk_info_text">
              <h1>
                AI Engineer and Investor for StartUPs<br />
                in Silicon Valley
              </h1>
              <p>
                Lorem ipsum dolor sit amet, consectetur adipiscing elit. Et,
                volutpat feugiat placerat lobortis.
              </p>
              <button class="btn_hire">HIRE ME</button>
            </div>

            <div class="musk_img">
              <img src="/author/images/Your Image 1.svg" alt="developer" />
            </div>
            
          </div>
         
          <section class="services">
  <h2>My Services</h2>
  <p class="services_desc">
    Amet minim mollit non deserunt ullamco est sit aliqua dolor<br>
    do amet sint. Velit officia consequat duis enim velit mollit.
  </p>

  <div class="service_grid">
    <div class="service_card">
      <img src="/author/images/Icons_coding.svg" alt="">
      <h4>Web Development</h4>
      <p>Blog, E-Commerce</p>
    </div>

    <div class="service_card">
      <img src="/author/images/Icons_illustration (1).svg" alt="">
      <h4>UI/UX Design</h4>
      <p>Mobile App, Website Design</p>
    </div>

    <div class="service_card">
      <img src="/author/images/Icons_Microphone (1).svg" alt="">
      <h4>Sound Design</h4>
      <p>Voice Over, Beat Making</p>
    </div>

    <div class="service_card">
      <img src="/author/images/Icons_game-development.svg" alt="">
      <h4>Game Design</h4>
      <p>Character Design, Props & Objects</p>
    </div>

    <div class="service_card">
      <img src="/author/images/Icons_Photographer.svg" alt="">
      <h4>Photography</h4>
      <p>Portrait, Product Photography</p>
    </div>

    <div class="service_card">
      <h4>Advertising</h4>
      <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
      <a href="#">ORDER NOW ›</a>
    </div>
  </div>
</section>
       
        
        
      </div>
      <div class="right_frame">
       <div class="right_frame">
          <a href="#" class="nav-icon active"><i class="fa fa-home"></i></a>
          <a href="#" class="nav-icon"><i class="fa fa-file-text"></i></a>
          <a href="#" class="nav-icon"><i class="fa fa-graduation-cap"></i></a>
          <a href="#" class="nav-icon"><i class="fa fa-user"></i></a>
          <a href="#" class="nav-icon"><i class="fa fa-briefcase"></i></a>
          <a href="#" class="nav-icon"><i class="fa fa-pencil"></i></a>
          <a href="#" class="nav-icon"><i class="fa fa-comment"></i></a>
        </div>
  
</div>
      </div>
    
  </body>
</html>
